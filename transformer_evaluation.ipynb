   "source": [
    "# Transformer Evaluation\n",
    "\n",
    "This notebook demonstrates the standalone evaluation of the Transformer-based summarization architecture used for metric comparison against the primary Mamba pipeline."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "sys.path.append(os.getcwd())\n",
    "from metrics import transformer_summarize, run_and_profile, compute_quality_metrics\n",
    "\n",
    "# Sample input data\n",
    "top_5_posts = \"\"\"\n",
    "AI is transforming the industry at an unprecedented pace. The new models released this week show a 20% improvement in reasoning tasks. \n",
    "Many developers are concerned about the ethical implications of AGI. However, researchers assure that guardrails are strict. \n",
    "The open-source community is booming with new fine-tuned models on HuggingFace. Local execution is becoming more viable than ever.\n",
    "\"\"\"\n",
    "\n",
    "print(\"Running Transformer Summarization...\")\n",
    "summary, time_taken, mem_used = run_and_profile(transformer_summarize, top_5_posts)\n",
    "\n",
    "print(\"\\n--- Results ---\")\n",
    "print(f\"Summary: {summary}\")\n",
    "print(f\"Inference Time: {time_taken:.2f} seconds\")\n",
    "print(f\"Memory Used: {mem_used:.2f} MB\")\n",
    "\n",
    "print(\"\\n--- Metrics ---\")\n",
    "metrics = compute_quality_metrics([summary], [top_5_posts])\n",
    "import pprint\n",
    "pprint.pprint(metrics[0])\n"
   ]
  }
